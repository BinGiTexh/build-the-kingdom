# =============================================================================
# JOB PLATFORM TEMPLATE - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# 
# For local development: docker-compose up
# For production: Configure in Terraform/CI/CD secrets
# =============================================================================

# -----------------------------------------------------------------------------
# SITE IDENTITY & BRANDING (White-Label Configuration)
# -----------------------------------------------------------------------------
SITE_NAME=Job Platform
SITE_TAGLINE=Find Your Dream Job
SITE_DOMAIN=localhost

# Logo and branding
LOGO_URL=/logo.svg
FAVICON_URL=/favicon.ico
PRIMARY_COLOR=#2563EB
SECONDARY_COLOR=#10B981
ACCENT_COLOR=#F59E0B

# -----------------------------------------------------------------------------
# LOCALIZATION
# -----------------------------------------------------------------------------
CURRENCY=USD
CURRENCY_SYMBOL=$
COUNTRY=
TIMEZONE=UTC
LANGUAGE=en
LOCATION_MODE=generic

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=
DB_NAME=jobplatform
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Google OAuth (optional — set GOOGLE_CLIENT_ID to enable)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# STRIPE PAYMENTS
# -----------------------------------------------------------------------------
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Pricing (in cents)
STRIPE_JOB_POSTING_PRICE=4999
STRIPE_FEATURED_LISTING_PRICE=9999

# -----------------------------------------------------------------------------
# FEED INGESTION (For Arb Model)
# -----------------------------------------------------------------------------
FEED_INGEST_ENABLED=true
FEED_INGEST_SCHEDULE=0 */6 * * *
FEED_URLS=

# -----------------------------------------------------------------------------
# EMAIL (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Job Platform

# -----------------------------------------------------------------------------
# FILE UPLOADS
# -----------------------------------------------------------------------------
STORAGE_TYPE=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

MAX_RESUME_SIZE=5242880
MAX_IMAGE_SIZE=2097152

# -----------------------------------------------------------------------------
# FEATURES
# -----------------------------------------------------------------------------
FEATURE_BETA_BANNER=false
FEATURE_FEED_INGEST=true
FEATURE_STRIPE=false
FEATURE_GOOGLE_AUTH=false

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:5000

# -----------------------------------------------------------------------------
# DEVELOPMENT
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# pgAdmin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# PRODUCTION
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=
