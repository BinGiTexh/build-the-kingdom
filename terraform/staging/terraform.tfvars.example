# Copy to terraform.tfvars and fill in values
# terraform.tfvars is gitignored — never commit secrets

aws_profile    = "personal"
aws_region     = "us-east-1"
project_name   = "buildthekingdom"
environment    = "staging"

# GitHub
github_repo    = "BinGiTexh/build-the-kingdom"
github_branch  = "main"

# Domain
domain         = "buildthekingdom.com"

# EC2
instance_type   = "t3.medium"
volume_size     = 30
ssh_key_name    = "my-key"
public_key_path = "~/.ssh/id_rsa.pub"
admin_cidr      = "YOUR_IP/32"

# Cloudflare Tunnel (create via Cloudflare dashboard first)
cloudflare_tunnel_id     = ""
cloudflare_tunnel_secret = ""
cloudflare_tunnel_token  = ""
cloudflare_account_tag   = ""

# Site Branding
site_name       = "Build The Kingdom"
site_tagline    = "Building Careers, Building Community"
primary_color   = "#2563EB"
secondary_color = "#10B981"
