# packages/frontend/Dockerfile.dev
# Development Dockerfile with hot-reload (Vite)

FROM node:22-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy source code (will be overwritten by volume mount)
COPY . .

# Expose Vite dev server port
EXPOSE 3000

# Development command
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
