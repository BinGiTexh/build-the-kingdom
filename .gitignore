# Dependencies
node_modules/
.pnp
.pnp.*
.npm
.yarn-integrity

# Environment & secrets — .env.example is the template; real values go in .env
.env
.env.*
!.env.example

# Credential / key files that forks may generate
*.pem
*.key
*.cert
*.p12
credentials.json
service-account*.json
secrets/

# Terraform — tfvars contain secrets; only .example files are committed
*.tfvars
!*.tfvars.example
.terraform/
*.tfstate
*.tfstate.*

# Docker
.docker
docker-compose.override.yml

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
build/
dist/
.next/
out/

# IDE
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# Caches
.eslintcache
*.tsbuildinfo

# REPL / pack
.node_repl_history
*.tgz

# Prisma migrations (generated per-fork)
packages/api/prisma/migrations/
!packages/api/prisma/migrations/.gitkeep

# Vercel
.vercel

# TypeScript
next-env.d.ts
